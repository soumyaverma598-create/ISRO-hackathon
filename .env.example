# Solar Sentinel AI Configuration

# Logging Level: debug, info, warning, error
LOG_LEVEL=info

# Data Simulation Parameters
# Number of simulated flare events per 24 hours
FLARE_EVENTS_PER_DAY=3
# Flare event magnitude multiplier (1.0 = baseline)
FLARE_MAGNITUDE_MULTIPLIER=1.0
# Add realistic noise to data
ADD_NOISE=true

# Prediction Engine Parameters
# Soft X-ray feature weight (0.0-1.0)
SOLEXS_WEIGHT=0.35
# Hard X-ray feature weight (0.0-1.0)
HELIOS_WEIGHT=0.35
# Temporal trend weight (0.0-1.0)
TREND_WEIGHT=0.20
# Volatility index weight (0.0-1.0)
VOLATILITY_WEIGHT=0.10

# Alert Thresholds
# Probability threshold for CRITICAL (RED) alert
CRITICAL_THRESHOLD=0.75
# Probability threshold for WARNING (ORANGE) alert
WARNING_THRESHOLD=0.50
# Probability threshold for ADVISORY (YELLOW) alert
ADVISORY_THRESHOLD=0.25

# UI/Theme Configuration
# Enable dark mode (true/false)
DARK_MODE=true
# Primary theme color (hex)
PRIMARY_COLOR=#00FF00
# Accent color (hex)
ACCENT_COLOR=#FF6600
# Background color (hex)
BG_COLOR=#0a0e27

# Data Source Configuration
# Data source: simulated, file, api
DATA_SOURCE=simulated
# For simulated: frequency in minutes
DATA_FREQUENCY=1
# For file: path to CSV file
# DATA_FILE_PATH=./data/historical.csv
# For API: endpoint URL
# DATA_API_URL=http://api.example.com/solar-data

# Advanced Configuration
# Enable model confidence scoring
ENABLE_CONFIDENCE_SCORE=true
# Enable feature importance (SHAP-style)
ENABLE_EXPLAINABILITY=true
# Enable historical data caching
ENABLE_CACHING=true
# Cache expiration time (minutes)
CACHE_EXPIRATION=60

# Development Configuration
# Debug mode (true/false)
DEBUG=false
# Verbose logging (true/false)
VERBOSE=false
# Port for local development
PORT=8501
# Host for local development
HOST=localhost
